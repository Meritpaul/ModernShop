# ══════════════════════════════════════════════════════════════════
#  ModernShop  —  Environment Variables Template
#  Copy this file to a new file named .env (starts with a dot)
#  Then fill in the actual values.
#  For local development you don't need a .env file — Django will use defaults.
# ══════════════════════════════════════════════════════════════════

# ── Site name ─────────────────────────────────────────────────────
# Full site name (appears in navbar, footer, email, admin panel)
# Leave empty to use the default "ModernShop"
SITE_NAME=ModernShop

# ── Security ──────────────────────────────────────────────────────
# Run this command to create a random key:
#   python -c "import secrets; print(secrets.token_hex(50))"
SECRET_KEY=

# Set to False on live servers
DEBUG=False

# Your domain(s), comma separated, no spaces
ALLOWED_HOSTS=yourdomain.com,www.yourdomain.com

# HTTPS URLs (for Django 4+ CSRF protection)
CSRF_TRUSTED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com

# ── Database (cPanel MySQL) ───────────────────────────────────────
# Not needed for local development (SQLite will be used)
DB_ENGINE=mysql
DB_NAME=cpanelusername_dbname
DB_USER=cpanelusername_dbuser
DB_PASSWORD=your_database_password
DB_HOST=localhost
DB_PORT=3306

# ── Email (optional) ──────────────────────────────────────────────
# If using Gmail, you need an App Password instead of your normal password
# (Google Account → Security → 2-Step Verification → App Passwords)
# Leave empty to disable email sending (local dev will print to console)
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
