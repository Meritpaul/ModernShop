# ══════════════════════════════════════════════════════════════════
#  ModernShop  —  Environment Variables Template
#  এই ফাইলটা copy করে নাম দাও  .env  (ডট দিয়ে শুরু)
#  তারপর আসল মানগুলো ভরো।
#  LOCAL dev-এ .env ফাইল লাগবে না — Django নিজেই default ব্যবহার করবে।
# ══════════════════════════════════════════════════════════════════

# ── Site name ─────────────────────────────────────────────────────
# পুরো সাইটের নাম (navbar, footer, email, admin panel সব জায়গায় দেখাবে)
# খালি রাখলে ডিফল্ট "ModernShop" ব্যবহার হবে
SITE_NAME=ModernShop

# ── Security ──────────────────────────────────────────────────────
# নিচের কমান্ড দিয়ে একটা random key বানাও:
#   python -c "import secrets; print(secrets.token_urlsafe(50))"
SECRET_KEY=

# Live সার্ভারে অবশ্যই False করবে
DEBUG=False

# তোমার domain (কমা দিয়ে, স্পেস ছাড়া)
ALLOWED_HOSTS=yourdomain.com,www.yourdomain.com

# HTTPS URL গুলো (Django 4+ এ CSRF protection-এর জন্য)
CSRF_TRUSTED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com

# ── Database (cPanel MySQL) ───────────────────────────────────────
# Local dev-এ এই section দরকার নেই (SQLite ব্যবহার হবে)
DB_ENGINE=mysql
DB_NAME=cpanelusername_dbname
DB_USER=cpanelusername_dbuser
DB_PASSWORD=your_database_password
DB_HOST=localhost
DB_PORT=3306

# ── Email (optional) ──────────────────────────────────────────────
# Gmail ব্যবহার করলে normal password না, App Password লাগবে
# (Google Account → Security → 2-Step Verification → App Passwords)
# খালি রাখলে email পাঠানো হবে না (Local dev-এর মতো console-এ print হবে)
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
